---
/**
 * Navbar — top-fixed navigation bar with scroll-spy, language toggle,
 * and dark/light theme toggle. Uses DaisyUI navbar + swap components.
 */
import { siteConfig, getLocaleData } from "../config/siteConfig";
import logoSrc from "../assets/images/brand/logo-placeholder.svg";

const currentLocale = Astro.currentLocale || "en";
const t = getLocaleData(currentLocale);
const nav = t.nav;

const navLinks = [
  { href: "#about", label: nav.about },
  { href: "#services", label: nav.services },
  { href: "#process", label: nav.process },
  { href: "#contact", label: nav.contact },
];

const toggleLangUrl = currentLocale === "th" ? "/" : "/th/";
const toggleLangText = currentLocale === "th" ? "EN" : "TH";
---

<div class="navbar bg-base-100/80 backdrop-blur-md fixed top-0 z-50 shadow-sm">
  <!-- Mobile dropdown -->
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-10 mt-3 w-52 p-2 shadow">
        {navLinks.map((link) => (
          <li><a href={link.href} data-nav-link>{link.label}</a></li>
        ))}
        <li class="mt-2">
          <a href={toggleLangUrl} data-lang-toggle class="badge badge-ghost">{toggleLangText}</a>
        </li>
      </ul>
    </div>
    <a href="#hero" class="btn btn-ghost text-xl">
      <img
        src={logoSrc.src}
        alt={siteConfig.businessName}
        width="200"
        height="60"
        loading="eager"
        decoding="async"
        class="h-8 w-auto"
      />
    </a>
  </div>

  <!-- Desktop center nav -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      {navLinks.map((link) => (
        <li><a href={link.href} data-nav-link class="font-medium">{link.label}</a></li>
      ))}
    </ul>
  </div>

  <!-- Right: theme toggle + language toggle -->
  <div class="navbar-end gap-1">
    <!-- Theme toggle -->
    <label id="themeToggle" class="btn btn-ghost btn-sm btn-circle swap swap-rotate">
      <input type="checkbox" id="themeCheckbox" aria-label="Toggle dark mode" />
      <!-- Sun icon — shown when dark theme is active -->
      <svg class="swap-on h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M5.64 17l-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1m7-7a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1M5.64 7.05a1 1 0 0 0 .7.29 1 1 0 0 0 .71-.29 1 1 0 0 0 0-1.41l-.71-.71A1 1 0 0 0 4.93 6.34zm12.02 9.36-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71a1 1 0 0 0-1.41-1.41M21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2m-2.64-7.95-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71a1 1 0 0 0-1.41-1.41M12 6.5A5.5 5.5 0 1 0 17.5 12 5.51 5.51 0 0 0 12 6.5m0 9A3.5 3.5 0 1 1 15.5 12 3.5 3.5 0 0 1 12 15.5M12 19a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1" />
      </svg>
      <!-- Moon icon — shown when light theme is active -->
      <svg class="swap-off h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73A8.15 8.15 0 0 1 9.08 5.49a8.59 8.59 0 0 1 .25-2 1 1 0 0 0-.35-1 1 1 0 0 0-1-.17A10 10 0 0 0 2 12a10 10 0 0 0 10 10 10.44 10.44 0 0 0 5.22-1.43 10.45 10.45 0 0 0 4.42-6.57 1 1 0 0 0 0-1" />
      </svg>
    </label>

    <!-- Language toggle (desktop) -->
    <a href={toggleLangUrl} data-lang-toggle class="btn btn-ghost btn-sm hidden lg:inline-flex">{toggleLangText}</a>
  </div>
</div>

<script>
  // ─── Scroll spy ───
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          document.querySelectorAll("[data-nav-link]").forEach((link) => {
            link.classList.toggle("active", link.getAttribute("href") === `#${id}`);
          });
        }
      });
    },
    { rootMargin: "0px 0px -70% 0px", threshold: 0 },
  );

  document.querySelectorAll("section[id]").forEach((s) => observer.observe(s));

  // ─── Language preference ───
  document.querySelectorAll("[data-lang-toggle]").forEach((el) => {
    el.addEventListener("click", () => {
      const href = (el as HTMLAnchorElement).getAttribute("href") ?? "/";
      localStorage.setItem("lang-pref", href.startsWith("/th") ? "th" : "en");
    });
  });

  // ─── Theme toggle ───
  const themeCheckbox = document.getElementById("themeCheckbox") as HTMLInputElement | null;
  const html = document.documentElement;
  const LIGHT = "corporate";
  const DARK = "business";

  // Initialise from saved preference or system
  const saved = localStorage.getItem("theme-pref");
  const prefersDark = saved === DARK || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches);
  if (prefersDark) {
    html.setAttribute("data-theme", DARK);
    if (themeCheckbox) themeCheckbox.checked = true;
  }

  themeCheckbox?.addEventListener("change", () => {
    const next = themeCheckbox.checked ? DARK : LIGHT;
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme-pref", next);
  });
</script>
