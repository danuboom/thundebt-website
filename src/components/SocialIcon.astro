---
interface Props {
  svg: string;
  viewBox?: string;
  class?: string;
}

const { svg, viewBox = "0 0 24 24", class: className = "h-5 w-5" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  fill="currentColor"
  class={className}
  aria-hidden="true"
>
  <path d={svg} />
</svg>
