---
/**
 * Hero — full-viewport landing section with gradient heading,
 * staggered fade-in animation, and dual CTA buttons.
 */
import { siteConfig, getLocaleData } from "../../config/siteConfig";
import heroBg from "../../assets/images/hero/hero-placeholder.svg";

const t = getLocaleData(Astro.currentLocale);
const { hero } = t;
---

<section id="hero" class="hero min-h-screen bg-primary text-primary-content relative overflow-hidden">
  <img
    src={heroBg.src}
    alt=""
    width="1920"
    height="1080"
    loading="eager"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover opacity-20 select-none mix-blend-overlay"
  />
  <div class="hero-content text-center">
    <div class="max-w-2xl">
      <h1 class="text-5xl font-extrabold tracking-tight md:text-7xl animate-fade-in-up">
        <span class="hero-gradient-text">{siteConfig.businessName}</span>
      </h1>
      <p class="py-6 text-xl opacity-80 md:text-2xl animate-fade-in-up-delay">{hero.headline}</p>
      <p class="mb-8 opacity-60 animate-fade-in-up-delay-2">{hero.subheadline}</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center animate-fade-in-up-delay-2">
        <a href={hero.cta.href} class="btn btn-accent btn-lg">{hero.cta.label}</a>
        <a href={hero.ctaSecondary.href} class="btn btn-ghost btn-lg border border-current/20">{hero.ctaSecondary.label}</a>
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-8 w-8 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
