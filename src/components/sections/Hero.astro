---
/**
 * Hero — full-width landing section with 2-column layout:
 * left = headline + CTAs, right = avatar with orbiting icon badges.
 * Credibility strip attached at the bottom.
 */
import { Image } from "astro:assets";
import { siteConfig, getContent } from "../../config/siteConfig";
import avatar from "../../assets/images/brand/thundebt-avatar.svg";

const { hero } = getContent();
const lineSocial = siteConfig.socials.find((s) => s.platform === "LINE");
---

<section id="hero" class="pt-20 pb-0 md:pt-24 relative overflow-hidden hero-bg">
  <!-- Subtle decorative blobs -->
  <div class="absolute top-10 right-0 w-80 h-80 bg-secondary/8 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="mx-auto w-full max-w-5xl px-6 relative">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
      <!-- Text column -->
      <div class="text-center md:text-left order-2 md:order-1">
        <h1 class="text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl text-base-content animate-fade-in-up">
          {hero.headline}
        </h1>
        <p class="mt-3 text-lg font-semibold text-primary md:text-xl animate-fade-in-up-delay">
          {hero.subheadline}
        </p>
        <p class="mt-2 text-base text-base-content/60 animate-fade-in-up-delay">
          {hero.description}
        </p>
        <div class="mt-5 flex flex-col sm:flex-row items-center gap-3 animate-fade-in-up-delay-2">
          <a href={hero.cta.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg w-full sm:w-auto">
            {hero.cta.label}
          </a>
          {lineSocial && (
            <a href={lineSocial.url} target="_blank" rel="noopener noreferrer" class="btn btn-lg gap-2 bg-white text-success border-base-300 hover:bg-base-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d={lineSocial.svg} />
              </svg>
              <span>แชทผ่าน LINE</span>
            </a>
          )}
        </div>
      </div>
      <!-- Avatar column with orbiting icon badges -->
      <div class="flex justify-center order-1 md:order-2 animate-fade-in-up">
        <div class="relative">
          <Image src={avatar} alt="THUNDEBT" class="w-40 md:w-56 lg:w-64 avatar-mascot relative z-10" />
          <!-- Floating debt type orbs with labels -->
          <div class="debt-orb absolute -top-4 -left-6 md:-left-12 animate-float-badge-1">
            <span class="debt-orb-icon">💳</span>
            <span class="debt-orb-label">{hero.debtTypes[0].label}</span>
          </div>
          <div class="debt-orb absolute top-1/4 -right-6 md:-right-14 animate-float-badge-2">
            <span class="debt-orb-icon">🚗</span>
            <span class="debt-orb-label">{hero.debtTypes[1].label}</span>
          </div>
          <div class="debt-orb absolute bottom-2 -left-4 md:-left-10 animate-float-badge-3">
            <span class="debt-orb-icon">🏠</span>
            <span class="debt-orb-label">{hero.debtTypes[2].label}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Credibility strip -->
  <div class="mt-8 bg-base-200/80 border-t border-b border-primary/5 py-4">
    <div class="mx-auto max-w-5xl px-6">
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm text-base-content/70">
        <svg class="w-5 h-5 text-primary/60 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        {hero.credibility.map((item, i) => (
          <>
            <span set:html={item.replace(/\*\*(.*?)\*\*/g, '<strong class="text-base-content font-semibold">$1</strong>')} />
            {i < hero.credibility.length - 1 && <span class="text-base-content/30">·</span>}
          </>
        ))}
      </div>
    </div>
  </div>
</section>
