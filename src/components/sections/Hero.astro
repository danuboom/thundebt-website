---
/**
 * Hero — full-viewport landing section with headline,
 * subheadline, and dual CTA buttons (app + LINE).
 */
import SocialIcon from "../SocialIcon.astro";
import { siteConfig, getContent } from "../../config/siteConfig";

const { hero } = getContent();
const lineSocial = siteConfig.socials.find((social) => social.platform === "LINE");
---

<section id="hero" class="hero min-h-screen bg-primary text-primary-content relative overflow-hidden">
  <div class="hero-content text-center px-4">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-6xl animate-fade-in-up">
        {hero.headline}
      </h1>
      <p class="py-6 text-lg opacity-80 md:text-xl animate-fade-in-up-delay">
        {hero.subheadline}
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center animate-fade-in-up-delay-2">
        <a href={hero.cta.href} target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-lg w-full sm:w-auto">
          {hero.cta.label}
        </a>
        <a href={hero.ctaSecondary.href} target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-lg border border-current/20 w-full sm:w-auto">
          {lineSocial && <SocialIcon svg={lineSocial.svg} class="h-5 w-5" />}
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-8 w-8 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
