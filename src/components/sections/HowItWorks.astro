---
/**
 * Section 3 — ระบบทำงานยังไง (How It Works)
 * 3-step process with DaisyUI steps + detail cards.
 */
import { getContent } from "../../config/siteConfig";

const { howItWorks } = getContent();
---

<section id="how-it-works" class="bg-base-200 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <div class="badge badge-primary badge-outline mb-3">{howItWorks.badge}</div>
      <h2 class="text-3xl font-bold md:text-4xl">{howItWorks.title}</h2>
    </div>

    <!-- Steps indicator -->
    <ul class="steps steps-vertical lg:steps-horizontal w-full mb-12">
      {howItWorks.steps.map((step) => (
        <li class="step step-primary">{step.title}</li>
      ))}
    </ul>

    <!-- Detail cards -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        howItWorks.steps.map((step, i) => (
          <div class="card bg-base-100 shadow-sm">
            <div class="card-body text-center md:text-left items-center md:items-start">
              <div class="badge badge-primary mb-2">
                {String(i + 1).padStart(2, "0")}
              </div>
              <h3 class="card-title text-base">{step.title}</h3>
              <p class="text-base-content/70 text-sm leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
