---
/**
 * Section 3 — Packages comparison cards
 * 3-column grid (2 plans now, expandable to 3).
 */
import { getContent } from "../../config/siteConfig";

const { packages } = getContent();
---

<section id="packages" class="py-10 md:py-14">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mb-10 text-center">
      <div class="badge badge-secondary badge-dot mb-3">{packages.badge}</div>
      <p class="mx-auto mb-3 max-w-3xl text-sm leading-7 text-base-content/65 md:text-base">
        {packages.lead}
      </p>
      <h2 class="text-3xl font-bold md:text-4xl">{packages.title}</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto items-stretch">
      {
        packages.plans.map((plan) => (
          <div class={`${plan.highlighted ? "indicator w-full" : ""}`}>
            {"badge" in plan && plan.badge && (
              <span class="indicator-item indicator-center badge badge-accent font-bold tracking-wide uppercase">
                {plan.badge}
              </span>
            )}
          <div class={`card bg-base-100 shadow-sm card-soft w-full h-full ${plan.highlighted ? "ring-2 ring-accent" : ""}`}>
            <div class="card-body p-6 flex flex-col justify-start [&>p]:grow-0">
              {/* Header */}
              <div class="text-center mb-4">
                <h3 class="text-lg font-bold text-base-content">{plan.name}</h3>
                <p class="text-sm text-base-content/60">{plan.subtitle}</p>
                <div class="mt-3">
                  {plan.price === 0 ? (
                    <span class="text-3xl font-extrabold text-base-content">ฟรี</span>
                  ) : (
                    <span>
                      <span class="text-3xl font-extrabold text-base-content">{plan.price}</span>
                      <span class="text-base font-bold text-base-content/70 ml-1">&#3647;</span>
                    </span>
                  )}
                </div>
              </div>

              {/* CTA */}
              <a
                href={plan.cta.href}
                target={plan.cta.href.startsWith("#") ? undefined : "_blank"}
                rel={plan.cta.href.startsWith("#") ? undefined : "noopener noreferrer"}
                class={`btn w-full mb-4 ${plan.highlighted ? "btn-accent" : "btn-outline btn-primary"}`}
              >
                {plan.cta.label}
              </a>

              {/* Subtitle */}
              <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-3">{packages.subtitle}</p>

              {/* Features */}
              <ul class="space-y-2.5 grow">
                {plan.features.map((f) => (
                  <li class="flex items-start gap-2">
                    {f.included === true ? (
                      <svg class="w-4 h-4 text-success mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    ) : f.included === "partial" ? (
                      <svg class="w-4 h-4 text-warning mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-base-content/20 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                      </svg>
                    )}
                    <div>
                      <span class={`text-sm ${f.included === false ? "text-base-content/40" : "text-base-content"}`}>{f.text}</span>
                      {f.detail && (
                        <p class={`text-xs mt-0.5 ${plan.highlighted ? "text-primary/60" : "text-base-content/40"}`}>{f.detail}</p>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
