---
import { getLocaleData } from "../../config/siteConfig";

const t = getLocaleData(Astro.currentLocale);
const { process } = t;
---

<section id="process" class="bg-base-100 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <div class="badge badge-primary badge-outline mb-3">{process.badge}</div>
      <h2 class="text-3xl font-bold md:text-4xl">{process.title}</h2>
    </div>

    <!-- Steps indicator -->
    <ul class="steps steps-vertical lg:steps-horizontal w-full mb-12">
      {process.steps.map((step) => (
        <li class="step step-primary">{step.title}</li>
      ))}
    </ul>

    <!-- Detail cards -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        process.steps.map((step, i) => (
          <div class="card bg-base-200 shadow-sm">
            <div class="card-body">
              <div class="badge badge-primary mb-2">
                {String(i + 1).padStart(2, "0")}
              </div>
              <h3 class="card-title text-base">{step.title}</h3>
              <p class="text-base-content/70 text-sm leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
