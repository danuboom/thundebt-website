---
import { getLocaleData } from "../../config/siteConfig";

const t = getLocaleData(Astro.currentLocale);
const { services } = t;
---

<section id="services" class="bg-base-200 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <div class="badge badge-accent badge-outline mb-3">{services.badge}</div>
      <h2 class="text-3xl font-bold md:text-4xl">{services.title}</h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.items.map((service) => (
          <div class="card bg-base-100 shadow-md hover:shadow-lg transition-shadow">
            <div class="card-body">
              <div class="text-4xl mb-2">{service.icon}</div>
              <h3 class="card-title">{service.title}</h3>
              <p class="text-base-content/70">{service.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
